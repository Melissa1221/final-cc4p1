# compilados y temporales
java/out/
*.class
__pycache__/
*.pyc
go/**/bin/
# el jar de FlatLaf SI se versiona (runtime local, sin internet)
!java/lib/*.jar

# artefactos generados de python
# toda la carpeta datos: dataset CIFAR (170MB), pesos entrenados (.npz),
# imagenes de detecciones. Nada de esto va al repo.
python/datos/
python/**/__pycache__/

# binarios go compilados
go/nodo-raft
go/**/gonodo*

# artefactos de build del cliente movil (android/gradle)
mobile/.gradle/
mobile/build/
mobile/app/build/
mobile/local.properties
mobile/.idea/
mobile/**/*.apk

# artefactos latex
docs/**/*.aux
docs/**/*.log
docs/**/*.nav
docs/**/*.out
docs/**/*.snm
docs/**/*.toc
# evidencia generada de python
python/datos/evidencia/
docs/**/*.vrb
